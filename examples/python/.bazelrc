build:lint --aspects=//tools/lint:linters.bzl%ruff
build:lint --aspects=//tools/lint:linters.bzl%flake8
build:lint --aspects=//tools/lint:linters.bzl%pylint
build:lint --aspects=//tools/lint:linters.bzl%pydoclint
build:lint --aspects=//tools/lint:linters.bzl%ty

# Build without the bytes
common:ci --remote_download_outputs=minimal
common:ci --nobuild_runfile_links

# Override the preset's `--lockfile_mode=error` on CI since we don't
# yet commit MODULE.bazel.lock — see .gitignore.
common:ci --lockfile_mode=off
